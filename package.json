{
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "node node_modules/vite/bin/vite.js --host 0.0.0.0",
        "build": "node node_modules/vite/bin/vite.js build",
        "serve": "php artisan serve --host=0.0.0.0 --port=8000",
        "start": "npm run dev",
        "static:dev": "node node_modules/vite/bin/vite.js --config vite.static.config.js --host 0.0.0.0",
        "static:build": "node node_modules/vite/bin/vite.js build --config vite.static.config.js"
    },
    "devDependencies": {
        "axios": "^1.8.2",
        "concurrently": "^9.1.2",
        "laravel-vite-plugin": "^2.0.0",
        "vite": "^7.0.0"
    }
}
